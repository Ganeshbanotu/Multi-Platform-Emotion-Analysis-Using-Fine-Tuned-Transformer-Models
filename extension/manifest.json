{
    "manifest_version": 3,
    "name": "SentiScope — Emotion Detector",
    "version": "1.0.0",
    "description": "Detect emotions in social media text on Twitter, Reddit and LinkedIn",
    "permissions": [ "activeTab", "storage" ],
    "host_permissions": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.reddit.com/*",
        "https://www.linkedin.com/*",
        "http://127.0.0.1:8000/*",
        "http://localhost:8000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://twitter.com/*",
                "https://x.com/*",
                "https://www.reddit.com/*",
                "https://www.linkedin.com/*"
            ],
            "js": [ "content.js" ],
            "css": [ "content.css" ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}